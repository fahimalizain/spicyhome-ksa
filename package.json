{
  "name": "spicyhome-ksa",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "pnpm --recursive test",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint --fix .",
    "format": "pnpm exec prettier --check .",
    "format:fix": "pnpm exec prettier --write .",
    "typecheck": "pnpm --recursive typecheck",
    "ensure-node24": "node -e \"process.exit(process.version.startsWith('v24.') ? 0 : 1)\" || (echo 'ERROR: Node 24 required. Run: nvm use' && exit 1)",
    "check": "pnpm lint && pnpm format && pnpm typecheck",
    "package:win7": "bash packaging/build-package.sh",
    "postinstall": "lefthook install",
    "lefthook": "lefthook"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@evilmartians/lefthook": "^2.1.10",
    "@types/node": "^18.19.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.9.6",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.65.0"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
